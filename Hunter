	},
	Death = {
		Type = "Guiding",
		Hints = {"Death", "Hints", "Go", "Here"},
		Cause = ""
	}
})

---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")

	local Reboundcolor = Instance.new("ColorCorrectionEffect")
	Reboundcolor.Name = "Warn"
	Reboundcolor.TintColor = Color3.fromRGB(200, 200, 200)
	Reboundcolor.Saturation = -0.7
	Reboundcolor.Contrast = 0.2
	Reboundcolor.Parent = game:GetService("Lighting")
	game:GetService("Debris"):AddItem(Reboundcolor, 24)

	TweenService:Create(
		Reboundcolor,
		TweenInfo.new(15),
		{ TintColor = Color3.fromRGB(200, 200, 200), Saturation = 0, Contrast = 0 }
	):Play()

	local TW = TweenService:Create(
		game.Lighting.MainColorCorrection,
		TweenInfo.new(5),
		{ TintColor = Color3.fromRGB(255, 255, 255) }
	)
	TW:Play()
end)

entity:SetCallback("OnStartMoving", function()
	print("Entity has started moving")
end)

entity:SetCallback("OnEnterRoom", function(room: Model, firstTime: boolean)
	if firstTime == true then
		print("Entity has entered room: " .. room.Name .. " for the first time")
	else
		print("Entity has entered room: " .. room.Name .. " again")
	end
end)

entity:SetCallback("OnLookAt", function(lineOfSight: boolean)
	if lineOfSight == true then
		print("Player is looking at entity")
	else
		print("Player view is obstructed by something")
	end
end)

entity:SetCallback("OnRebounding", function(startOfRebound: boolean)
	if startOfRebound == true then
		print("Entity has started rebounding")
	else
		print("Entity has finished rebounding")
	end
end)

entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")
end)

entity:SetCallback("OnDespawned", function()
	print("Entity has despawned")
end)

entity:SetCallback("OnDamagePlayer", function(newHealth)
	if newHealth == 0 then
		print("Entity has killed the player")
		return
	end

	print("Entity has damaged the player")

	task.spawn(function()
		local player = Players.LocalPlayer
		local character = player.Character or player.CharacterAdded:Wait()
		local humanoid = character:WaitForChild("Humanoid", 5)
		local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
		local camera = workspace.CurrentCamera

		local entityModel = workspace:WaitForChild("HunterMoving", 5)
		if not entityModel then
			return
		end

		local primaryPart = entityModel:FindFirstChild("Hunter", true)
		if not primaryPart then
			primaryPart = entityModel.PrimaryPart or entityModel:FindFirstChildWhichIsA("BasePart", true)
		end

		if not (humanoid and humanoidRootPart and primaryPart and camera) then
			return
		end

		-- Khóa di chuyển người chơi
		local originalWalkSpeed = humanoid.WalkSpeed
		local originalJumpPower = humanoid.JumpPower
		humanoid.WalkSpeed = 0
		humanoid.JumpPower = 0

		-- Khóa điều khiển an toàn
		local controlsModule
		do
			local playerScripts = player:FindFirstChild("PlayerScripts")
			local playerModule = playerScripts and playerScripts:FindFirstChild("PlayerModule")
			if playerModule then
				local ok, controls = pcall(function()
					return require(playerModule):GetControls()
				end)
				if ok then
					controlsModule = controls
					if controlsModule and controlsModule.Disable then
						controlsModule:Disable()
					end
				end
			end
		end

		-- Đưa entity theo người chơi bằng tween ngắn
		local to = true
		task.spawn(function()
			while to and primaryPart.Parent and humanoidRootPart.Parent do
				local targetCFrame = humanoidRootPart.CFrame
				local tween = TweenService:Create(primaryPart, TweenInfo.new(2000000000000, Enum.EasingStyle.Quad), {CFrame = targetCFrame})
				tween:Play()
				tween.Completed:Wait()
			end
		end)
		task.wait(0.05)

		local ripeAttachment = primaryPart:FindFirstChild("Base", true)
		if ripeAttachment then
			local emitter = ripeAttachment:FindFirstChild("Face")
			if emitter and emitter:IsA("ParticleEmitter") then
				emitter.Texture = "rbxassetid://11110560177"
				emitter.Enabled = true
				emitter.TimeScale = 0
			end
		end

		task.wait(0.35)

		local function SetAllParticlesTimeScale(model, timescale)
			for _, descendant in ipairs(model:GetDescendants()) do
				if descendant:IsA("ParticleEmitter") then
					descendant.TimeScale = timescale
					print("Set TimeScale = " .. timescale .. " cho ParticleEmitter:", descendant.Name)
				end
			end
		end

		SetAllParticlesTimeScale(entityModel, 0)

		camera.CameraType = Enum.CameraType.Scriptable

		local lockConnection
		lockConnection = RunService.RenderStepped:Connect(function()
			if not primaryPart or not primaryPart.Parent then
				if lockConnection then
					lockConnection:Disconnect()
				end
				return
			end
			camera.CFrame = CFrame.lookAt(camera.CFrame.Position, primaryPart.Position)
		end)

		local function MakeSound(soundId, volume, playbackSpeed)
			local s = Instance.new("Sound")
			s.SoundId = "rbxassetid://" .. tostring(soundId)
			s.Volume = volume or 1
			s.PlaybackSpeed = playbackSpeed or 1
			s.Parent = workspace
			return s
		end

		local function CreateTextLabel(parent, text)
			local label = Instance.new("TextLabel")
			label.Name = "JumpscareText"
			label.BackgroundTransparency = 1
			label.BorderSizePixel = 0
			label.AnchorPoint = Vector2.new(0.5, 0.5)
			label.Position = UDim2.fromScale(0.5, 0.58)
			label.Size = UDim2.new(0.9, 0, 0.12, 0)
			label.Font = Enum.Font.GothamBlack
			label.Text = text
			label.TextScaled = true
			label.TextColor3 = Color3.fromRGB(255, 255, 255)
			label.TextStrokeTransparency = 0
			label.TextTransparency = 1
			label.ZIndex = 50
			label.Parent = parent

			local stroke = Instance.new("UIStroke")
			stroke.Thickness = 3
			stroke.Color = Color3.fromRGB(0, 0, 0)
			stroke.Transparency = 0
			stroke.Parent = label

			return label
		end

		local function FadeText(label, targetTransparency, duration)
			local tween = TweenService:Create(
				label,
				TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
				{ TextTransparency = targetTransparency }
			)
			tween:Play()
			return tween
		end

		for _, descendant in ipairs(entityModel:GetDescendants()) do
			if descendant:IsA("Sound") then
				descendant.Playing = false
				descendant.Volume = 0
			end
		end

		task.wait(0.5)

		-- GUI jumpscare
		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "JumpscareOverlay"
		screenGui.IgnoreGuiInset = true
		screenGui.DisplayOrder = 999999
		screenGui.ResetOnSpawn = false
		screenGui.Parent = player:WaitForChild("PlayerGui")

		local staticLabel = Instance.new("ImageLabel")
		staticLabel.Name = "StaticLabel"
		staticLabel.BackgroundTransparency = 1
		staticLabel.BorderSizePixel = 0
		staticLabel.Position = UDim2.fromScale(0, 0)
		staticLabel.Size = UDim2.fromScale(1, 1)
		staticLabel.ScaleType = Enum.ScaleType.Stretch
		staticLabel.ImageTransparency = 0
		staticLabel.Visible = true
		staticLabel.Parent = screenGui

		local jumpLabel = Instance.new("ImageLabel")
		jumpLabel.Name = "JumpLabel"
		jumpLabel.BackgroundTransparency = 1
		jumpLabel.BorderSizePixel = 0
		jumpLabel.AnchorPoint = Vector2.new(0.5, 0.5)
		jumpLabel.Position = UDim2.fromScale(0.5, 0.5)
		jumpLabel.Size = UDim2.new(0, 150, 0, 150)
		jumpLabel.ScaleType = Enum.ScaleType.Stretch
		jumpLabel.Image = "rbxassetid://16332986504"
		jumpLabel.ImageTransparency = 0
		jumpLabel.Visible = true
		jumpLabel.Parent = screenGui

		local staticImage1 = "rbxassetid://94547864377343"
		local staticImage2 = "rbxassetid://236542974"

		local staticSound = MakeSound(134625236300564, 1, 1)
		staticSound.Looped = true
		staticSound:Play()

		-- Static chớp luân phiên 2 ảnh
		local staticRunning = true
		task.spawn(function()
			local toggle = false
			while staticRunning and screenGui and screenGui.Parent do
				toggle = not toggle
				staticLabel.Image = toggle and staticImage1 or staticImage2
				staticLabel.ImageTransparency = 0
				task.wait(0.05)
			end
		end)

		task.wait(2)

		local text1 = CreateTextLabel(screenGui, "why you hide me?")
		FadeText(text1, 0, 0.2)

		task.wait(3)

		local text1Out = FadeText(text1, 1, 2)
		text1Out.Completed:Wait()
		if text1 and text1.Parent then
			text1:Destroy()
		end

		local text2 = CreateTextLabel(screenGui, "Goodbye YOU....")
		FadeText(text2, 0, 0.2)

		local fadeOutJump = TweenService:Create(
			jumpLabel,
			TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
			{ ImageTransparency = 1 }
		)
		fadeOutJump:Play()
		fadeOutJump.Completed:Wait()

		task.wait(1)

		local expandSound1 = MakeSound(135750666095391, 1, 1)
		local expandSound2 = MakeSound(133358860191747, 1, 1)
		expandSound1:Play()
		expandSound2:Play()

		jumpLabel.ImageTransparency = 0

		loadstring(game:HttpGet("https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Jumpscare%20Hunter"))()

		task.wait(0)

		local deathHintRemote = game.ReplicatedStorage:FindFirstChild("RemotesFolder") and game.ReplicatedStorage.RemotesFolder:FindFirstChild("DeathHint")
		local hintsTable = {
			"You died to who you call Ripper",
			"he will get faster every he go a room",
			"Hide in a closet if he spawn."
		}

		if typeof(firesignal) == "function" and deathHintRemote then
			pcall(function()
				firesignal(deathHintRemote.OnClientEvent, hintsTable, "Blue")
			end)
		end

		to = false

		if screenGui and screenGui.Parent then
			screenGui:Destroy()
		end

		if staticSound then staticSound:Stop() staticSound:Destroy() end
		if expandSound1 then expandSound1:Stop() expandSound1:Destroy() end
		if expandSound2 then expandSound2:Stop() expandSound2:Destroy() end

		if humanoid then
			humanoid.Health = 0
		end

		if entityModel and entityModel.Parent then
			entityModel:Destroy()
		end

		if lockConnection then
			lockConnection:Disconnect()
		end

		camera.CameraType = Enum.CameraType.Custom

		if humanoid and humanoid.Health > 0 then
			humanoid.WalkSpeed = originalWalkSpeed
			humanoid.JumpPower = originalJumpPower
			if controlsModule and controlsModule.Enable then
				controlsModule:Enable()
			end
		end
	end)
end)

---====== Run entity ======---

entity:Run()
