			Enabled = false,
			Duration = 1
		},
		Shatter = true,
		Repair = false
	},
	Earthquake = {
		Enabled = false
	},
	CameraShake = {
		Enabled = true,
		Range = 100,
		Values = {30, 100, 0.1, 0.1}
	},
	Movement = {
		Speed = 200,
		Delay = 5,
		Reversed = true
	},
	Rebounding = {
		Enabled = true,
		Type = "Ambush",
		Min = 4,
		Max = 4,
		Delay = 0
	},
	Damage = {
		Enabled = true,
		Range = 40,
		Amount = 0.00001
	},
	Crucifixion = {
		Enabled = true,
		Range = 40,
		Resist = false,
