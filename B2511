---====== Speed ramp helper ======---

local speedLoopRunning = false
local speedCurrent = 0
local running = true -- ĐÃ FIX: Chuyển lên làm biến cục bộ chung để OnDespawning có thể tắt được vòng lặp hình ảnh

local function setEntitySpeed(value)
	value = math.clamp(value, 0, 400)

	-- ĐÃ FIX: Thay đổi cách cấu hình trực tiếp vào meta-config của Spawner V2
	if entity then
		for _, key in ipairs({"Config", "Configuration", "config"}) do
			if entity[key] and entity[key].Movement then
				entity[key].Movement.Speed = value
			end
		end
	end
	
	-- ĐÃ FIX: Đồng thời ép trực tiếp thuộc tính Speed vào Object vật lý trong Workspace nếu Spawner tạo ra
	local b25Model = workspace:FindFirstChild("B25")
	if b25Model then
		local config = b25Model:FindFirstChild("Config") or b25Model:FindFirstChild("Configuration")
		if config then
			local speedVal = config:FindFirstChild("Speed")
			if speedVal and speedVal:IsA("ValueBase") then
				speedVal.Value = value
			end
		end
	end
end

local function startSpeedRamp()
	if speedLoopRunning then
		return
	end

	speedLoopRunning = true
	speedCurrent = 0
	setEntitySpeed(0)

	task.spawn(function()
		while speedLoopRunning do
			speedCurrent = math.min(speedCurrent + 10, 400)
			setEntitySpeed(speedCurrent)

			if speedCurrent >= 400 then
				break
			end

			task.wait(0.05)
		end
	end)
end

local function resetSpeed()
	speedLoopRunning = false
	speedCurrent = 0
	setEntitySpeed(0)
end

