local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

--=========================================
--      HÀM SPAWN DREADCLOCK 11%
--=========================================
local function spawnDreadClock(room)

	-- 11% tỉ lệ xuất hiện
	if math.random(1, 100) > 11 then
		return -- Không spawn
	end

	--== TẠO MODEL DREADCLOCK ==--
	local omg = Instance.new("Model")
	omg.Name = "DreadClock"
	omg.Parent = room

	--== LẤY MODEL EYES ==--
	local eyes = game:GetObjects("rbxassetid://114894440433899")[1]
	eyes.Parent = omg

	--== ĐẢM BẢO PRIMARYPART ==--
	if not eyes.PrimaryPart then
		for _, v in ipairs(eyes:GetChildren()) do
			if v:IsA("BasePart") then
				eyes.PrimaryPart = v
				break
			end
		end
	end
	local mainPart = eyes.PrimaryPart

	--=====================================
	--        TÌM GIỮA PHÒNG
	--=====================================
	local centerCFrame
	local nodes = room:FindFirstChild("PathfindNodes")

	if nodes then
		local children = nodes:GetChildren()
		table.sort(children, function(a,b) return tonumber(a.Name) < tonumber(b.Name) end)
		centerCFrame = children[math.floor(#children/2)].CFrame
	else
		centerCFrame = room:FindFirstChild(room.Name).CFrame
	end

	eyes:PivotTo(centerCFrame + Vector3.new(0, 5, 0))

	------------------------------------------------
	--          PROXIMITY PROMPT DOORS
	------------------------------------------------
	local prompt = Instance.new("ProximityPrompt")
	prompt.ObjectText = "Strange Device"
	prompt.ActionText = "Collect"
	prompt.HoldDuration = 4
	prompt.Style = Enum.ProximityPromptStyle.Custom
	prompt.RequiresLineOfSight = false
	prompt.MaxActivationDistance = 20

	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.Parent = mainPart

	--== SỰ KIỆN KHI NHẶT ==--
	prompt.Triggered:Connect(function(plr)

		local pick = math.random(1, 4)

	if pick == 1 then
	-- Flashlight
			loadstring(game:HttpGet("https://raw.githubusercontent.com/eoyoustme/back/refs/heads/main/Crucifix"))()
			require(plr.PlayerGui.MainUI.Initiator.Main_Game)
			omg:Destroy()
		.caption("Command block has granted you a Flashlight!", true)

elseif pick == 2 then
	-- Entity xấu 1
			loadstring(game:HttpGet("https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Camperbad"))()
			require(plr.PlayerGui.MainUI.Initiator.Main_Game)
			omg:Destroy()
		.caption("Oh no! You have bad luck, an entity has spawned", true)

elseif pick == 3 then
	-- Entity xấu 2
			loadstring(game:HttpGet("https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Waiter"))()
			require(plr.PlayerGui.MainUI.Initiator.Main_Game)
			omg:Destroy()
		.caption("Oh no! You have bad luck, an entity has spawned", true)

elseif pick == 4 then
	-- Entity xấu 3
	loadstring(game:HttpGet("https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Glitcher2"))()
			require(plr.PlayerGui.MainUI.Initiator.Main_Game)
			omg:Destroy()
		.caption("Oh no! You have bad luck, an entity has spawned", true)
end

omg:Destroy()
end)
end

--====================================================
--     LẶP LẠI MỖI LẦN QUA PHÒNG MỚI (AUTO)
--====================================================
RS.GameData.LatestRoom.Changed:Connect(function()
	task.wait(0.25)

	local roomNumber = RS.GameData.LatestRoom.Value
	local room = workspace.CurrentRooms:FindFirstChild(roomNumber)

	if room then
		spawnDreadClock(room)  -- gọi spawn theo tỉ lệ 11%
		end
end)
