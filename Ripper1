	game.Lighting.MainColorCorrection.Contrast = 0.01
	local tween = game:GetService("TweenService")
	tween:Create(game.Lighting.MainColorCorrection, TweenInfo.new(2.5), {Contrast = 0}):Play()
	local TweenService = game:GetService("TweenService")
	local TW = TweenService:Create(game.Lighting.MainColorCorrection, TweenInfo.new(7.551),{TintColor = Color3.fromRGB(255, 0, 0)})
	TW:Play()
	
	wait(5.771)
	
	game.Lighting.MainColorCorrection.TintColor = Color3.fromRGB(255, 0, 0)
	game.Lighting.MainColorCorrection.Contrast = 0.01
	local tween = game:GetService("TweenService")
	tween:Create(game.Lighting.MainColorCorrection, TweenInfo.new(2.5), {Contrast = 0}):Play()
	local TweenService = game:GetService("TweenService")
	local TW2 = TweenService:Create(game.Lighting.MainColorCorrection, TweenInfo.new(5.771),{TintColor = Color3.fromRGB(255, 255, 255)})
	TW2:Play()
	
end)

