local Speed = 10

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
local Camera = Workspace.CurrentCamera

local modelUrl = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Chaser.rbxm"
local modelFile = "Chaser.rbxm"

if not isfile(modelFile) then
	writefile(modelFile, game:HttpGet(modelUrl))
end

local ok, objects = pcall(function()
	return game:GetObjects((getcustomasset or getsynasset)(modelFile))
end)

if not ok or not objects or not objects[1] then
	warn("Failed to load model from GitHub")
	return
end

local Dummy = objects[1]
Dummy.Parent = workspace

local entityRoot = Dummy:FindFirstChild("RushNew", true) or Dummy.PrimaryPart or Dummy:FindFirstChildWhichIsA("BasePart", true)
if not entityRoot then
	warn("Model is missing RushNew/BasePart")
	Dummy:Destroy()
	return
end

if Dummy.PrimaryPart == nil then
	Dummy.PrimaryPart = entityRoot
end

for _, inst in ipairs(Dummy:GetDescendants()) do
	if inst:IsA("BasePart") then
		inst.CanCollide = false
		inst.Anchored = false
	end
end

Dummy:PivotTo(Character.HumanoidRootPart.CFrame + Vector3.new(math.random(0, 50), 0, math.random(0, 50)))
task.wait(1)

local function followPlayer()
	if not Character.Parent then
		return
	end

	local charHRP = Character:FindFirstChild("HumanoidRootPart")
	if not charHRP then
		return
	end

	local offset = charHRP.Position - entityRoot.Position
	if offset.Magnitude < 0.001 then
		return
	end

	local direction = offset.Unit
	entityRoot.AssemblyLinearVelocity = direction * Speed
	entityRoot.CFrame = CFrame.new(entityRoot.Position, charHRP.Position)
end

local renderConn
renderConn = RunService.RenderStepped:Connect(function()
	if Dummy:IsDescendantOf(workspace) and entityRoot and entityRoot.Parent then
		followPlayer()
	end
end)

task.spawn(function()
	while task.wait(3) do
		if not Dummy.Parent then
			break
		end

		local light = entityRoot:FindFirstChildWhichIsA("PointLight", true)
		local radio = Dummy:FindFirstChild("Radio Static Sound", true)

		if light then
			TweenService:Create(light, TweenInfo.new(3, Enum.EasingStyle.Linear), { Range = math.random(10, 25) }):Play()
			TweenService:Create(light, TweenInfo.new(3, Enum.EasingStyle.Linear), { Brightness = math.random(5, 50) }):Play()
		end

		if radio and radio:IsA("Sound") then
			TweenService:Create(radio, TweenInfo.new(3, Enum.EasingStyle.Linear), { Volume = 2 }):Play()
			TweenService:Create(radio, TweenInfo.new(3, Enum.EasingStyle.Linear), { PlaybackSpeed = math.random(1, 5) }):Play()
		end
	end
end)

local death = true
local cleanupDone = false
local originalFOV = Camera.FieldOfView
local originalWalkSpeed = Humanoid.WalkSpeed

local function GetGitSound(GithubSnd, SoundName)
	local url = GithubSnd
	if not isfile(SoundName .. ".mp3") then
		writefile(SoundName .. ".mp3", game:HttpGet(url))
	end

	local sound = Instance.new("Sound")
	sound.SoundId = (getcustomasset or getsynasset)(SoundName .. ".mp3")
	return sound
end

local fireEmitters = {}

local function ForceChaseStats()
	Camera.FieldOfView = 90
	Humanoid.WalkSpeed = 20
end

local function ApplyFireToMap()
	local currentRooms = Workspace:FindFirstChild("CurrentRooms")
	if not currentRooms then
		return
	end

	-- Giữ FOV / tốc độ ở mức này trong lúc chase còn chạy
	ForceChaseStats()

	for _, inst in ipairs(currentRooms:GetDescendants()) do
		if inst:IsA("BasePart") and not inst:IsDescendantOf(Dummy) and not inst:IsDescendantOf(Character) then
			if not inst:FindFirstChild("MapFire") then
				local fire = Instance.new("ParticleEmitter")
				fire.Name = "MapFire"
				fire.Texture = "rbxasset://textures/particles/fire_main.dds"
				fire.Color = ColorSequence.new(Color3.fromRGB(255, 120, 0), Color3.fromRGB(255, 0, 0))
				fire.LightEmission = 1
				fire.Size = NumberSequence.new({
					NumberSequenceKeypoint.new(0, 3),
					NumberSequenceKeypoint.new(1, 0)
				})
				fire.Lifetime = NumberRange.new(0.6, 1.1)
				fire.Rate = 25
				fire.Speed = NumberRange.new(2, 6)
				fire.Rotation = NumberRange.new(0, 360)
				fire.RotSpeed = NumberRange.new(-120, 120)
				fire.SpreadAngle = Vector2.new(25, 25)
				fire.Enabled = true
				fire.Parent = inst

				table.insert(fireEmitters, fire)
			end
		end
	end
end

local latestRoom = ReplicatedStorage:WaitForChild("GameData"):WaitForChild("LatestRoom")

latestRoom.Changed:Connect(function()
	ApplyFireToMap()
end)

local redGui = Instance.new("ScreenGui")
redGui.Name = "RedOverlayGui"
redGui.ResetOnSpawn = false
redGui.IgnoreGuiInset = true
redGui.DisplayOrder = 999999
redGui.Parent = Player:WaitForChild("PlayerGui")

local redFrame = Instance.new("Frame")
redFrame.Name = "RedFrame"
redFrame.Size = UDim2.fromScale(1, 1)
redFrame.Position = UDim2.fromScale(0, 0)
redFrame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
redFrame.BackgroundTransparency = 1
redFrame.BorderSizePixel = 0
redFrame.Parent = redGui

local colorFx = Instance.new("ColorCorrectionEffect")
colorFx.Name = "ChaserRedFX"
colorFx.TintColor = Color3.fromRGB(255, 0, 0)
colorFx.Saturation = -0.15
colorFx.Contrast = 0.2
colorFx.Parent = Lighting

Camera.FieldOfView = 90

local Jumpscare = GetGitSound(
	"https://github.com/eoyoustme/Extremely/blob/main/Schoolhouse%20Madness%202%20Subterbaldi%20Ost.mp3?raw=true",
	"Subter"
)
Jumpscare.Parent = workspace
Jumpscare.Volume = 3
Jumpscare.PlaybackSpeed = 1
Jumpscare:Play()

Humanoid.WalkSpeed = 20

task.spawn(function()
	while task.wait() do
		if not death then
			break
		end

		if not Dummy.Parent or not entityRoot.Parent then
			break
		end

		local target = Character:FindFirstChild("HumanoidRootPart")
		if not target then
			continue
		end

		local origin = entityRoot.Position
		local direction = target.Position - origin
		if direction.Magnitude <= 0 then
			continue
		end

		local raycast = workspace:Raycast(origin, direction.Unit * 5)
		if raycast and raycast.Instance and raycast.Instance:IsDescendantOf(Character) then
			if not Character:GetAttribute("Hiding") then
				Humanoid:TakeDamage(1000)
				local stats = ReplicatedStorage:FindFirstChild("GameStats")
				if stats and stats:FindFirstChild("Player_" .. Player.Name) then
					stats["Player_" .. Player.Name].Total.DeathCause.Value = "Chaser"
				end
			end
		end
	end
end)

ApplyFireToMap()

task.delay(116, function()
	if cleanupDone then
		return
	end
	cleanupDone = true
	death = false

	if Jumpscare then
		Jumpscare:Stop()
		Jumpscare:Destroy()
	end

	if redGui then
		redGui:Destroy()
	end

	if colorFx then
		colorFx:Destroy()
	end

	for _, fire in ipairs(fireEmitters) do
		if fire and fire.Parent then
			fire:Destroy()
		end
	end

	Camera.FieldOfView = originalFOV
	Humanoid.WalkSpeed = originalWalkSpeed

	if renderConn then
		renderConn:Disconnect()
	end

	if Dummy and Dummy.Parent then
			Dummy:Destroy()
	end
end)
