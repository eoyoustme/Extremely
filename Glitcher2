local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

local function GetGitSound(GithubSnd, SoundName)
	local url = GithubSnd
	if not isfile(SoundName .. ".mp3") then
		writefile(SoundName .. ".mp3", game:HttpGet(url))
	end

	local sound = Instance.new("Sound")
	sound.SoundId = (getcustomasset or getsynasset)(SoundName .. ".mp3")
	return sound
end

local function GetCurrentRoom()
	local currentRooms = Workspace:FindFirstChild("CurrentRooms")
	if not currentRooms then
		return nil
	end

	local latestRoom = game.ReplicatedStorage:WaitForChild("GameData"):WaitForChild("LatestRoom")
	return currentRooms:FindFirstChild(tostring(latestRoom.Value))
end

local function IsExcludedPart(part, entityModel, character)
	if not part or not part.Parent then
		return true
	end

	if entityModel and part:IsDescendantOf(entityModel) then
		return true
	end

	if character and part:IsDescendantOf(character) then
		return true
	end

	return false
end

local function GetGlitchParts(entityModel)
	local parts = {}
	local character = player.Character

	local currentRooms = Workspace:FindFirstChild("CurrentRooms")
	if not currentRooms then
		return parts
	end

	for _, inst in ipairs(currentRooms:GetDescendants()) do
		if inst:IsA("BasePart") and not IsExcludedPart(inst, entityModel, character) then
			table.insert(parts, inst)
		end
	end

	return parts
end

local function StartRoomGlitch(entityModel, duration)
	local stopped = false
	local endTime = os.clock() + duration

	task.spawn(function()
		local grow = true
		while not stopped and os.clock() < endTime do
			local scale = grow and 1.2 or (1 / 1.3)
			local currentRooms = Workspace:FindFirstChild("CurrentRooms")

			if currentRooms then
				for _, room in ipairs(currentRooms:GetChildren()) do
					if room:IsA("Model") then
						pcall(function()
							room:ScaleTo(scale)
						end)
					end
				end
			end

			grow = not grow
			task.wait(0.12)
		end
	end)

	task.spawn(function()
		while not stopped and os.clock() < endTime do
			local parts = GetGlitchParts(entityModel)

			for _, part in ipairs(parts) do
				if part and part.Parent then
					part.CFrame = part.CFrame * CFrame.Angles(0, math.rad(2), math.rad(2))
				end
			end

			task.wait()
		end
	end)

	task.spawn(function()
		local cc = Instance.new("ColorCorrectionEffect")
		cc.Name = "GlitchFX"
		cc.TintColor = Color3.fromRGB(255, 0, 0)
		cc.Saturation = -0.1
		cc.Contrast = 0.15
		cc.Parent = Lighting

		local blur = Instance.new("BlurEffect")
		blur.Name = "GlitchBlur"
		blur.Size = 0
		blur.Parent = Lighting

		while not stopped and os.clock() < endTime do
			cc.TintColor = (math.random(1, 3) == 1)
				and Color3.fromRGB(255, 0, 0)
				or Color3.fromRGB(255, 255, 255)

			cc.Saturation = math.random(-10, 0) / 10
			cc.Contrast = math.random(0, 3) / 10
			blur.Size = math.random(0, 16)

			task.wait(0.05)
		end

		if cc then cc:Destroy() end
		if blur then blur:Destroy() end
	end)

	return function()
		stopped = true
	end
end


