entity:SetCallback("OnDamagePlayer", function(newHealth: number)
	if newHealth <= 0 then
		print("Entity has killed the player")
		return
	end

	print("Entity has damaged the player")

	task.spawn(function()
		local character = player.Character or player.CharacterAdded:Wait()
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")

		local entityModel = workspace:FindFirstChild("Glitcher")
		local primaryPart = entityModel and entityModel:FindFirstChild("Glitcher")

		if not (entityModel and primaryPart and humanoid and humanoidRootPart and camera) then
			return
		end

		local originalCameraType = camera.CameraType
		camera.CameraType = Enum.CameraType.Scriptable

		local lockConnection
		lockConnection = RunService.RenderStepped:Connect(function()
			if not primaryPart or not primaryPart.Parent then
				if lockConnection then
					lockConnection:Disconnect()
				end
				return
			end

			camera.CFrame = CFrame.lookAt(camera.CFrame.Position, primaryPart.Position)
		end)

		local stopGlitch = StartRoomGlitch(entityModel, 2.0)

		local Jumpscare = GetGitSound(
			"https://github.com/eoyoustme/Extremely/blob/main/Glitcher.mp3?raw=true",
			"Glitcher"
		)
		Jumpscare.Parent = workspace
		Jumpscare.Volume = 3
		Jumpscare.PlaybackSpeed = 1
		Jumpscare:Play()

		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "JumpscareOverlay"
		screenGui.IgnoreGuiInset = true
		screenGui.DisplayOrder = 999999
		screenGui.ResetOnSpawn = false
		screenGui.Parent = player:WaitForChild("PlayerGui")

		local staticImage = Instance.new("ImageLabel")
		staticImage.Name = "Static"
		staticImage.BackgroundTransparency = 1
		staticImage.BorderSizePixel = 0
		staticImage.Size = UDim2.fromScale(1, 1)
		staticImage.Position = UDim2.fromScale(0, 0)
		staticImage.Image = "rbxassetid://0"
		staticImage.ImageTransparency = 0
		staticImage.ScaleType = Enum.ScaleType.Stretch
		staticImage.Parent = screenGui

		local staticImage2 = Instance.new("ImageLabel")
		staticImage2.Name = "Static2"
		staticImage2.BackgroundTransparency = 1
		staticImage2.BorderSizePixel = 0
		staticImage2.Size = UDim2.fromScale(1, 1)
		staticImage2.Position = UDim2.fromScale(0, 0)
		staticImage2.Image = "rbxassetid://0"
		staticImage2.ImageTransparency = 1
		staticImage2.ScaleType = Enum.ScaleType.Stretch
		staticImage2.Parent = screenGui

		TweenService:Create(
			staticImage,
			TweenInfo.new(0.15, Enum.EasingStyle.Linear),
			{ ImageTransparency = 0 }
		):Play()

		local t0 = os.clock()
		while os.clock() - t0 < 2 do
			staticImage.ImageTransparency = 0
			staticImage2.ImageTransparency = 1
			task.wait(0.05)
			staticImage.ImageTransparency = 1
			staticImage2.ImageTransparency = 0
			task.wait(0.05)
		end

		if humanoid and humanoid.Health > 0 then
			humanoid.Health = 0
		end

		if stopGlitch then
			stopGlitch()
		end

		if lockConnection then
			lockConnection:Disconnect()
		end

		camera.CameraType = originalCameraType

		if screenGui then
			screenGui:Destroy()
		end

		if Jumpscare then
			Jumpscare:Destroy()
		end

		if entityModel and entityModel.Parent then
			entityModel:Destroy()
		end
	end)
	end)

