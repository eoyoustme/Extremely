local function rollChance(percent)
	return math.random(1, 100) <= percent
end

local function spawnEntity(entityData)
	pcall(function()
		loadstring(game:HttpGet(entityData.url))()
	end)
end

math.randomseed(tick() % 1 * 1e7)

while true do
	wait(10)

	for _, entityData in ipairs(entityList) do
		if rollChance(entityData.chance) then
			spawnEntity(entityData)
		end
	end
end
