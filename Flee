sound.SoundId = "rbxassetid://125686568414089"
sound.Volume = 10
sound.Parent = workspace
sound:Play()

task.wait(3)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
local Camera = Workspace.CurrentCamera

local function refreshCharacter()
	Character = Player.Character or Player.CharacterAdded:Wait()
	Humanoid = Character:WaitForChild("Humanoid")
	HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
end

Player.CharacterAdded:Connect(function()
	task.wait(0.1)
	refreshCharacter()
end)

local modelUrl = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Flee.rbxm"
local modelFile = "Flee.rbxm"

if not isfile(modelFile) then
	writefile(modelFile, game:HttpGet(modelUrl))
end

local ok, objects = pcall(function()
	return game:GetObjects((getcustomasset or getsynasset)(modelFile))
end)

if not ok or not objects or not objects[1] then
	warn("Failed to load model from GitHub")
	return
end

local Dummy = objects[1]
Dummy.Parent = workspace

local entityRoot = Dummy:FindFirstChild("RushNew", true) or Dummy.PrimaryPart or Dummy:FindFirstChildWhichIsA("BasePart", true)
if not entityRoot then
	warn("Model is missing RushNew/BasePart")
	Dummy:Destroy()
	return
end

if Dummy.PrimaryPart == nil then
	Dummy.PrimaryPart = entityRoot
end

local function setModelAnchored(state)
	for _, inst in ipairs(Dummy:GetDescendants()) do
		if inst:IsA("BasePart") then
			inst.Anchored = state
			if inst.Name ~= "AttackZone" then
				inst.CanCollide = false
				inst.CanTouch = false
				inst.CanQuery = false
			end
		end
	end
end

setModelAnchored(true)

local function getSpawnPositionInFront()
	local hrp = Character:FindFirstChild("HumanoidRootPart")
	if not hrp then
		return Vector3.new(0, 30, 0)
	end

	-- Spawn đúng trước mặt player 20 studs, không raycast xuống đất
	return hrp.Position + (hrp.CFrame.LookVector * 20)
end

local spawnPos = getSpawnPositionInFront()
Dummy:PivotTo(CFrame.new(spawnPos, Character.HumanoidRootPart.Position))

local attackZone = Instance.new("Part")
attackZone.Name = "AttackZone"
attackZone.Size = Vector3.new(5, 5, 5)
attackZone.Transparency = 1
attackZone.Anchored = true
attackZone.CanCollide = false
attackZone.CanTouch = true
attackZone.CanQuery = false
attackZone.Massless = true
attackZone.Parent = Dummy

local attackEnabled = false
local attackLocked = false
local chaseEnabled = false
local teleportDistance = 5

local function setAttackEnabled(state)
	attackEnabled = state
	attackZone.CanTouch = state
end

attackZone.Touched:Connect(function(hit)
	if not attackEnabled then
		return
	end

	if attackLocked then
		return
	end

	if not Character or not Character.Parent then
		return
	end

	if Character:GetAttribute("Hiding") then
		return
	end

	if hit and hit:IsDescendantOf(Character) then
		attackLocked = true
		setAttackEnabled(false)

		if Humanoid and Humanoid.Health > 0 then
			Humanoid:TakeDamage(50)
			loadstring(game:HttpGet("https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Flee%20Jumpscare"))()
		end

		local stats = ReplicatedStorage:FindFirstChild("GameStats")
		if stats and stats:FindFirstChild("Player_" .. Player.Name) then
			local playerStat = stats["Player_" .. Player.Name]
			if playerStat:FindFirstChild("Total") and playerStat.Total:FindFirstChild("DeathCause") then
				playerStat.Total.DeathCause.Value = "Flee"
			end
		end
	end
end)

local function followPlayerTeleport()
	if not Dummy.Parent then
		return
	end

	if not Character or not Character.Parent then
		return
	end

	local hrp = Character:FindFirstChild("HumanoidRootPart")
	if not hrp then
		return
	end

	local currentSpeed = Humanoid and Humanoid.WalkSpeed or 0
	local shouldChase = currentSpeed > 18

	if not shouldChase then
		chaseEnabled = false
		if not attackLocked then
			setAttackEnabled(false)
		end
		Dummy:PivotTo(CFrame.new(Dummy:GetPivot().Position, hrp.Position))
		attackZone.CFrame = Dummy:GetPivot()
		return
	end

	chaseEnabled = true
	if not attackLocked then
		setAttackEnabled(true)
	end

	local originPos = Dummy:GetPivot().Position
	local direction = hrp.Position - originPos
	local dist = direction.Magnitude

	if dist <= 7 then
		Dummy:PivotTo(CFrame.new(hrp.Position, hrp.Position + hrp.CFrame.LookVector))
		attackZone.CFrame = Dummy:GetPivot()
		return
	end

	if dist < 0.001 then
		return
	end

	local moveDist = math.min(teleportDistance, dist)
	local newPos = originPos + direction.Unit * moveDist

	Dummy:PivotTo(CFrame.new(newPos, hrp.Position))
	attackZone.CFrame = Dummy:GetPivot()
end

task.spawn(function()
	while task.wait(0.1) do
		if not Dummy or not Dummy.Parent then
			break
		end

		if not Character or not Character.Parent then
			continue
		end

		followPlayerTeleport()
	end
end)

local latestRoom = ReplicatedStorage:WaitForChild("GameData"):WaitForChild("LatestRoom")
local roomChangeCount = 0
local cleaned = false

local function cleanup()
	if cleaned then
		return
	end
	cleaned = true

	setAttackEnabled(false)

	if Dummy and Dummy.Parent then
		Dummy:Destroy()
	end
end

local roomConn
roomConn = latestRoom.Changed:Connect(function()
	roomChangeCount += 1
	if roomChangeCount >= 5 then
		if roomConn then
			roomConn:Disconnect()
		end
		cleanup()
	end
end)

Dummy:PivotTo(Dummy:GetPivot())
attackZone.CFrame = Dummy:GetPivot()
setAttackEnabled(Humanoid.WalkSpeed > 18 and not attackLocked)
