---====== Speed ramp ======---

local speedRampRunning = false

local function resetSpeed()
	if entity and entity.Config and entity.Config.Movement then
		entity.Config.Movement.Speed = 10
	end
end

---====== Debug entity ======---

local running = true

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")

	local part = workspace:WaitForChild("B25")
	local object = part:WaitForChild("RushNew")
	local attachment = object:WaitForChild("MonsterGui")
	local emitter = attachment:FindFirstChild("Image1")

	object.CanCollide = false
	running = true

	task.spawn(function()
		while running and emitter and emitter:IsDescendantOf(workspace) do
			local Image = {
				"rbxassetid://14171480196",
				"rbxassetid://14176171052",
				"rbxassetid://14176175100",
				"rbxassetid://14952583096"
			}

			for _, Img in ipairs(Image) do
				if not running then
					break
				end
				emitter.Image = Img
				task.wait(0.1)
			end
		end
	end)
end)

entity:SetCallback("OnStartMoving", function()
	print("Entity has started moving")
	while true do
		task.wait(0.1)
		entity.Config.Movement.Speed = entity.Config.Movement.Speed * 1.3
		end
end)

entity:SetCallback("OnEnterRoom", function(room: Model, firstTime: boolean)
	if firstTime == true then
		print("Entity has entered room: ".. room.Name.. " for the first time")
	else
		print("Entity has entered room: ".. room.Name.. " again")
	end
end)

entity:SetCallback("OnLookAt", function(lineOfSight: boolean)
	if lineOfSight == true then
		print("Player is looking at entity")
		local Players = game:GetService("Players")
		local player = Players.LocalPlayer		
		local playerGui = player:WaitForChild("PlayerGui")

		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "JumpscareGui"
		screenGui.ResetOnSpawn = false
		screenGui.IgnoreGuiInset = true
		screenGui.DisplayOrder = 999999
		screenGui.Parent = playerGui

		local background = Instance.new("Frame")
		background.Name = "Background"
		background.Size = UDim2.fromScale(1, 1)
		background.Position = UDim2.fromScale(0, 0)
		background.BackgroundColor3 = Color3.new(0, 0, 0)
		background.BackgroundTransparency = 1
		background.BorderSizePixel = 0
		background.Parent = screenGui

		local imageLabel = Instance.new("ImageLabel")
		imageLabel.Name = "ImageLabel"
		imageLabel.BackgroundTransparency = 1
		imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
		imageLabel.Position = UDim2.fromScale(0.5, 0.5)
		imageLabel.Size = UDim2.new(0, 0.001, 0, 0.001)
		imageLabel.ImageTransparency = 0.8
		imageLabel.Image = "rbxassetid://2862136"
		imageLabel.Parent = background

		task.wait(3)
		screenGui:Destroy()
	else
		print("Player view is obstructed by something")
	end
end)

entity:SetCallback("OnRebounding", function(startOfRebound: boolean)
	if startOfRebound == true then
		print("Entity has started rebounding")
	else
		print("Entity has finished rebounding")
		speedRampRunning = false
		resetSpeed()

		local sound = Instance.new("Sound")
		sound.SoundId = "rbxassetid://2609993518"
		sound.Volume = 10
		sound.Parent = workspace
		sound:Play()
		game:GetService("Debris"):AddItem(sound, 5)
	end
end)

entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")
	running = false
	speedRampRunning = false
	resetSpeed()
end)

entity:SetCallback("OnDespawned", function()
	print("Entity has despawned")
	speedRampRunning = false
	resetSpeed()
end)

entity:SetCallback("OnDamagePlayer", function(newHealth: number)
	if newHealth <= 0 then
		print("Entity has killed the player")
		local Players = game:GetService("Players")
		local TweenService = game:GetService("TweenService")

		local player = Players.LocalPlayer
		local playerGui = player:WaitForChild("PlayerGui")
		local rng = Random.new()

		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "JumpscareGui"
		screenGui.ResetOnSpawn = false
		screenGui.IgnoreGuiInset = true
		screenGui.DisplayOrder = 999999
		screenGui.Parent = playerGui

		local background = Instance.new("Frame")
		background.Name = "Background"
		background.Size = UDim2.fromScale(1, 1)
		background.Position = UDim2.fromScale(0, 0)
		background.BackgroundColor3 = Color3.new(0, 0, 0)
		background.BorderSizePixel = 0
		background.Parent = screenGui

		local imageLabel = Instance.new("ImageLabel")
		imageLabel.Name = "ImageLabel"
		imageLabel.BackgroundTransparency = 1
		imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
		imageLabel.Position = UDim2.fromScale(0.5, 0.5)
		imageLabel.Size = UDim2.new(0, 0.001, 0, 0.001)
		imageLabel.Image = "rbxassetid://15392627860"
		imageLabel.Parent = background

		local jumpscareSound = Instance.new("Sound")
		jumpscareSound.Name = "Jumpscare"
		jumpscareSound.SoundId = "rbxassetid://6459610652"
		jumpscareSound.Volume = 10
		jumpscareSound.PlaybackSpeed = 1.8
		jumpscareSound.Parent = imageLabel

		local dis = Instance.new("DistortionSoundEffect")
		dis.Level = 1
		dis.Enabled = true
		dis.Parent = jumpscareSound

		local pitch = Instance.new("PitchShiftSoundEffect")
		pitch.Octave = 0.62
		pitch.Enabled = true
		pitch.Parent = jumpscareSound

		local chorus = Instance.new("ChorusSoundEffect")
		chorus.Depth = 0.15
		chorus.Mix = 0.5
		chorus.Rate = 0.5
		chorus.Enabled = true
		chorus.Parent = jumpscareSound

		local echo = Instance.new("EchoSoundEffect")
		echo.Delay = 0.02
		echo.Feedback = 1
		echo.Enabled = true
		echo.Parent = jumpscareSound

		jumpscareSound:Play()

		local fullTween = TweenService:Create(
			imageLabel,
			TweenInfo.new(2, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
			{
				Size = UDim2.new(0, 1250, 0, 1250)
			}
		)

		fullTween:Play()

		for i = 1, 40 do
			local mode = rng:NextInteger(1, 3)

			if mode == 1 then
				background.BackgroundColor3 = Color3.new(0, 0, 0)
				imageLabel.ImageColor3 = Color3.new(0, 1, 1)
				imageLabel.Position = UDim2.new(rng:NextNumber(0.4, 0.6), 0, rng:NextNumber(0.4, 0.6), 0)
			elseif mode == 2 then
				background.BackgroundColor3 = Color3.new(0, 0, 0)
				imageLabel.ImageColor3 = Color3.new(0, 0, 0)
				imageLabel.Position = UDim2.new(rng:NextNumber(0.4, 0.6), 0, rng:NextNumber(0.4, 0.6), 0)
			else
				background.BackgroundColor3 = Color3.new(0, 1, 1)
				imageLabel.ImageColor3 = Color3.new(0, 1, 1)
				imageLabel.Position = UDim2.new(rng:NextNumber(0.4, 0.6), 0, rng:NextNumber(0.4, 0.6), 0)
			end

			imageLabel.Rotation = rng:NextInteger(-30, 30)
			task.wait(0.01)
		end

		screenGui:Destroy()
		imageLabel:Destroy()
		background:Destroy()
	else
		print("Entity has damaged the player")
	end
end)

