---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://3359047385"
	sound.Volume = 10
	sound:Play()
	script.Parent = workspace
	
	local CameraShaker = require(game.ReplicatedStorage.CameraShaker)
	local camara = game.Workspace.CurrentCamera
	local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value, function(shakeCf)
		camara.CFrame = camara.CFrame * shakeCf
	end)
	camShake:Start()
	camShake:ShakeOnce(10,3,0.1,6,2,0.5)
	
	local Lighting = game:GetService("Lighting")
	local TweenService = game:GetService("TweenService")

	-- Tạo hoặc tìm MainColorCorrection
	local colorCorrection = Lighting:FindFirstChild("MainColorCorrection")
	if not colorCorrection then
		colorCorrection = Instance.new("ColorCorrectionEffect")
		colorCorrection.Name = "MainColorCorrection"
		colorCorrection.Parent = Lighting
	end

	-- Thiết lập ban đầu
	colorCorrection.TintColor = Color3.fromRGB(255, 255, 255)
	colorCorrection.Contrast = 0.1

	-- Tween giảm contrast xuống 0 trong 2.5 giây
	TweenService:Create(colorCorrection, TweenInfo.new(2.5), {Contrast = 0}):Play()

	-- Chuyển sang màu đỏ trong 5 giây
	local redTween = TweenService:Create(colorCorrection, TweenInfo.new(5), {TintColor = Color3.fromRGB(0, 0, 255)})
	redTween:Play()

	-- Chờ tween màu đỏ hoàn tất
	task.wait(0.5)

	-- Danh sách các màu để đổi
	local colors = {
		Color3.fromRGB(170, 0, 0),   -- Vàng
		Color3.fromRGB(0, 0, 255),     -- Xanh dương
		Color3.fromRGB(255, 255, 0),     -- Xanh lá
		Color3.fromRGB(0, 170, 0)  -- Hồng
	}

	-- Lặp 4 lần đổi màu
	for _ = 1, 2 do
		for _, color in ipairs(colors) do
			local tween = TweenService:Create(colorCorrection, TweenInfo.new(0.7), {TintColor = color})
			tween:Play()
			task.wait(0.5)
		end
	end

	-- Sau khi hoàn tất, chuyển lại về màu đỏ
	local finalRed = TweenService:Create(colorCorrection, TweenInfo.new(1), {TintColor = Color3.fromRGB(250, 0, 0)})
	finalRed:Play()
end)

