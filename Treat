local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local Lighting = game:GetService("Lighting")

local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

local Speed = 15
local SpawnDistance = 500
local ChaseDistance = 50
local ChaseDuration = 30

local alive = true
local chasing = false

local function getCharacter()
	Character = Player.Character or Player.CharacterAdded:Wait()
	Humanoid = Character:WaitForChild("Humanoid")
	HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
end

Player.CharacterAdded:Connect(function()
	getCharacter()
end)

local function getTargetPart()
	if Character and Character.Parent then
		local head = Character:FindFirstChild("Head")
		if head then
			return head
		end
		local hrp = Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			return hrp
		end
	end
	return HumanoidRootPart
end

local function makeGui()
	local old = Player:FindFirstChildOfClass("PlayerGui"):FindFirstChild("TreatWarnGui")
	if old then
		old:Destroy()
	end

	local gui = Instance.new("ScreenGui")
	gui.Name = "TreatWarnGui"
	gui.ResetOnSpawn = false
	gui.IgnoreGuiInset = true
	gui.DisplayOrder = 999999
	gui.Parent = Player:WaitForChild("PlayerGui")

	local bg = Instance.new("Frame")
	bg.Name = "BG"
	bg.Size = UDim2.fromScale(1, 1)
	bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	bg.BackgroundTransparency = 1
	bg.BorderSizePixel = 0
	bg.Parent = gui

	local label = Instance.new("TextLabel")
	label.Name = "Text"
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Position = UDim2.fromScale(0.5, 0.2)
	label.Size = UDim2.new(0.7, 0, 0.12, 0)
	label.BackgroundTransparency = 1
	label.Text = ""
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.Font = Enum.Font.GothamBlack
	label.TextScaled = true
	label.Parent = bg

	local flash = Instance.new("Frame")
	flash.Name = "Flash"
	flash.Size = UDim2.fromScale(1, 1)
	flash.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	flash.BackgroundTransparency = 1
	flash.BorderSizePixel = 0
	flash.Parent = bg

	return gui, bg, label, flash
end

local function flashScreen(flashFrame)
	if not flashFrame then
		return
	end

	flashFrame.BackgroundTransparency = 0.7
	local t1 = TweenService:Create(flashFrame, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {BackgroundTransparency = 1})
	t1:Play()
end

local function playPulseSound(parentObj)
	local sound = Instance.new("Sound")
	sound.SoundId = "rbxassetid://3359047385"
	sound.Volume = 2
	sound.PlaybackSpeed = 1
	sound.Parent = parentObj
	sound:Play()
	Debris:AddItem(sound, 5)
end

local function applyRedEffect()
	local cc = Instance.new("ColorCorrectionEffect")
	cc.Name = "TreatRed"
	cc.TintColor = Color3.fromRGB(255, 0, 0)
	cc.Saturation = -0.1
	cc.Contrast = 0.2
	cc.Parent = Lighting
	Debris:AddItem(cc, 1)
	return cc
end

local function spawnDummy()
	local Dummy = game:GetObjects("https://github.com/eoyoustme/Extremely/blob/main/Treat.rbxm?raw=true")[1]
	if not Dummy then
		error("Không load được Treat.rbxm")
	end

	Dummy.Parent = workspace

	local root = Dummy:FindFirstChild("HumanoidRootPart") or Dummy.PrimaryPart or Dummy:FindFirstChildWhichIsA("BasePart")
	if not root then
		error("Dummy không có HumanoidRootPart/BasePart")
	end

	if Dummy:IsA("Model") and not Dummy.PrimaryPart then
		Dummy.PrimaryPart = root
	end

	for _, v in ipairs(Dummy:GetDescendants()) do
		if v:IsA("BasePart") then
			v.CanCollide = false
			v.Anchored = false
		end
	end

	local angle = math.random() * math.pi * 2
	local offset = Vector3.new(math.cos(angle) * SpawnDistance, 0, math.sin(angle) * SpawnDistance)
	local spawnPos = HumanoidRootPart.Position + offset + Vector3.new(0, 0, 0)

	Dummy:PivotTo(CFrame.new(spawnPos, HumanoidRootPart.Position))

	return Dummy, root
end

local function attachFollow(dummyModel, rootPart)
	local conn
	conn = RunService.RenderStepped:Connect(function()
		if not alive then
			if conn then conn:Disconnect() end
			return
		end

		if not dummyModel or not dummyModel.Parent then
			if conn then conn:Disconnect() end
			return
		end

		if not Character or not Character.Parent then
			getCharacter()
		end

		local targetPart = getTargetPart()
		if not targetPart or not targetPart.Parent then
			return
		end

		local origin = rootPart.Position
		local targetPos = targetPart.Position
		local distance = (targetPos - origin).Magnitude

		if distance > 0.001 then
			local dir = (targetPos - origin).Unit
			rootPart.AssemblyLinearVelocity = dir * Speed
			rootPart.CFrame = CFrame.new(origin, targetPos)
		end
	end)

	return conn
end

local function chasePhase(dummyModel, rootPart)
	chasing = true
	local gui, bg, label, flash = makeGui()

	local soundHost = dummyModel:FindFirstChild("Head") or rootPart or dummyModel
	local chaseStart = tick()

	label.Text = "RUN! IS NEAR YOU"

	task.spawn(function()
		while alive and chasing and tick() - chaseStart < ChaseDuration do
			if gui and gui.Parent then
				bg.BackgroundTransparency = 0.25
				label.Text = "RUN! IS NEAR YOU"
				label.TextColor3 = Color3.fromRGB(255, 0, 0)
				flashScreen(flash)
				playPulseSound(soundHost)
				applyRedEffect()
			end
			task.wait(1)
		end
	end)

	local followConn = attachFollow(dummyModel, rootPart)

	task.wait(ChaseDuration)

	chasing = false
	alive = false

	if followConn then
		followConn:Disconnect()
	end

	if gui then
		local blink = 0
		while blink < 6 do
			if not gui.Parent then
				break
			end
			bg.BackgroundTransparency = 0.2
			label.Text = ""
			flash.BackgroundTransparency = 0.1
			task.wait(0.1)
			bg.BackgroundTransparency = 1
			flash.BackgroundTransparency = 1
			task.wait(0.1)
			blink += 1
		end
		gui:Destroy()
	end

	if dummyModel and dummyModel.Parent then
		dummyModel:Destroy()
	end
end

local function countdownPhase(gui, bg, label, flash)
	label.Text = "IS 500 STUD OVER YOU"
	label.TextColor3 = Color3.fromRGB(255, 255, 255)

	task.wait(1)

	for i = 5, 1, -1 do
		if not alive then
			return
		end
		label.Text = tostring(i)
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		flashScreen(flash)
		task.wait(1)
	end

	label.Text = "0"
	task.wait(0.2)
end

task.spawn(function()
	getCharacter()

	local gui, bg, label, flash = makeGui()

	local Dummy, rootPart = spawnDummy()

	-- Giữ dummy đi theo người chơi từ rất xa
	local followConn = attachFollow(Dummy, rootPart)

	-- Hiện cảnh báo ban đầu
	countdownPhase(gui, bg, label, flash)

	-- Chuyển sang chase khi tới 0
	if followConn then
		followConn:Disconnect()
	end

	if gui and gui.Parent then
		gui:Destroy()
	end

	if Dummy and Dummy.Parent then
		chasePhase(Dummy, rootPart)
	end
end)
