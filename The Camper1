local function tintCurrentRoomRed()
	local currentRooms = Workspace:FindFirstChild("CurrentRooms")
	local gameData = ReplicatedStorage:FindFirstChild("GameData")
	local latestRoom = gameData and gameData:FindFirstChild("LatestRoom")

	if not currentRooms or not latestRoom then
		return
	end

	local room = currentRooms:FindFirstChild(tostring(latestRoom.Value))
	if not room then
		return
	end

	local tweenInfo = TweenInfo.new(2.5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
	local goal = { Color = Color3.fromRGB(255, 0, 0) }

	for _, v in ipairs(room:GetDescendants()) do
		if v:IsA("Light") then
			TweenService:Create(v, tweenInfo, goal):Play()
		elseif v.Parent and v.Parent.Name == "LightFixture" then
			if v.Parent:IsA("BasePart") then
				TweenService:Create(v.Parent, tweenInfo, goal):Play()
			end
		end
	end
end

local function createLookJumpscare()
	local player = Players.LocalPlayer
	if not player then
		return
	end

	local playerGui = player:WaitForChild("PlayerGui")

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "JumpscareGui"
	screenGui.ResetOnSpawn = false
	screenGui.IgnoreGuiInset = true
	screenGui.DisplayOrder = 999999
	screenGui.Parent = playerGui

	local background = Instance.new("Frame")
	background.Name = "Background"
	background.Size = UDim2.fromScale(1, 1)
	background.Position = UDim2.fromScale(0, 0)
	background.BackgroundColor3 = Color3.new(0, 0, 0)
	background.BackgroundTransparency = 1
	background.BorderSizePixel = 0
	background.Parent = screenGui

	local imageLabel = Instance.new("ImageLabel")
	imageLabel.Name = "ImageLabel"
	imageLabel.BackgroundTransparency = 1
	imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
	imageLabel.Position = UDim2.fromScale(0.5, 0.5)
	imageLabel.Size = UDim2.new(0, 1, 0, 1)
	imageLabel.ImageTransparency = 0.8
	imageLabel.Image = "rbxassetid://2862136"
	imageLabel.Parent = background

	task.wait(3)

	if screenGui then
		screenGui:Destroy()
	end
end

local function createDeathJumpscare()
	local player = Players.LocalPlayer
	if not player then
		return
	end

	local playerGui = player:WaitForChild("PlayerGui")

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "JumpscareGui"
	screenGui.ResetOnSpawn = false
	screenGui.IgnoreGuiInset = true
	screenGui.DisplayOrder = 999999
	screenGui.Parent = playerGui

	local background = Instance.new("Frame")
	background.Name = "Background"
	background.Size = UDim2.fromScale(1, 1)
	background.Position = UDim2.fromScale(0, 0)
	background.BackgroundColor3 = Color3.new(0, 0, 0)
	background.BorderSizePixel = 0
	background.Parent = screenGui

	local imageLabel = Instance.new("ImageLabel")
	imageLabel.Name = "ImageLabel"
	imageLabel.BackgroundTransparency = 1
	imageLabel.AnchorPoint = Vector2.new(0.5, 0.5)
	imageLabel.Position = UDim2.fromScale(0.5, 0.5)
	imageLabel.Size = UDim2.new(0, 1, 0, 1)
	imageLabel.Image = "rbxassetid://11481753252"
	imageLabel.Parent = background

	local jumpscareSound = Instance.new("Sound")
	jumpscareSound.Name = "Jumpscare"
	jumpscareSound.SoundId = "rbxassetid://8011939545"
	jumpscareSound.Volume = 10
	jumpscareSound.PlaybackSpeed = 1
	jumpscareSound.Parent = imageLabel

	local dis = Instance.new("DistortionSoundEffect")
	dis.Level = 1
	dis.Enabled = true
	dis.Parent = jumpscareSound

	local pitch = Instance.new("PitchShiftSoundEffect")
	pitch.Octave = 0.62
	pitch.Enabled = true
	pitch.Parent = jumpscareSound

	local chorus = Instance.new("ChorusSoundEffect")
	chorus.Depth = 0.15
	chorus.Mix = 0.5
	chorus.Rate = 0.5
	chorus.Enabled = true
	chorus.Parent = jumpscareSound

	local echo = Instance.new("EchoSoundEffect")
	echo.Delay = 0.02
	echo.Feedback = 1
	echo.Enabled = true
	echo.Parent = jumpscareSound

	jumpscareSound:Play()

	local fullTween = TweenService:Create(
		imageLabel,
		TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{
			Size = UDim2.new(0, 1250, 0, 1250)
		}
	)
	fullTween:Play()

	for _ = 1, 100 do
		local mode = rng:NextInteger(1, 3)

		if mode == 1 then
			jumpscareSound.PlaybackSpeed = 0.2
			background.BackgroundColor3 = Color3.new(0, 0, 0)
			imageLabel.ImageColor3 = Color3.new(1, 0, 0)
			imageLabel.Position = UDim2.new(rng:NextNumber(0.2, 0.8), 0, rng:NextNumber(0.2, 0.8), 0)
		elseif mode == 2 then
			jumpscareSound.PlaybackSpeed = 0.8
			background.BackgroundColor3 = Color3.new(0, 0, 0)
			imageLabel.ImageColor3 = Color3.new(1, 0, 0)
			imageLabel.Position = UDim2.new(rng:NextNumber(0.2, 0.8), 0, rng:NextNumber(0.2, 0.8), 0)
		else
			jumpscareSound.PlaybackSpeed = 1.2
			background.BackgroundColor3 = Color3.new(1, 0, 0)
			imageLabel.ImageColor3 = Color3.new(1, 0, 0)
			imageLabel.Position = UDim2.new(rng:NextNumber(0.2, 0.8), 0, rng:NextNumber(0.2, 0.8), 0)
		end

		imageLabel.Rotation = rng:NextInteger(-30, 30)
		task.wait(0.01)
	end

	local tween1 = TweenService:Create(
		imageLabel,
		TweenInfo.new(0.5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{
			ImageTransparency = 1
		}
	)
	tween1:Play()

	jumpscareSound.PlaybackSpeed = 0.7
	imageLabel.Rotation = rng:NextInteger(-30, 30)
	imageLabel.Position = UDim2.new(rng:NextNumber(0.2, 0.8), 0, rng:NextNumber(0.2, 0.8), 0)
	imageLabel.Size = UDim2.new(0, 750, 0, 750)

	task.wait(0.5)

	jumpscareSound.PlaybackSpeed = 0.4
	imageLabel.Rotation = rng:NextInteger(-30, 30)
	imageLabel.Position = UDim2.new(rng:NextNumber(0.2, 0.8), 0, rng:NextNumber(0.2, 0.8), 0)
	imageLabel.ImageTransparency = 0
	imageLabel.Size = UDim2.new(0, 550, 0, 550)

	local tween2 = TweenService:Create(
		imageLabel,
		TweenInfo.new(0.5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{
			ImageTransparency = 1
		}
	)
	tween2:Play()

	task.wait(0.5)

	imageLabel.Rotation = rng:NextInteger(-30, 30)
	imageLabel.Position = UDim2.new(rng:NextNumber(0.2, 0.8), 0, rng:NextNumber(0.2, 0.8), 0)
	imageLabel.ImageTransparency = 0
	imageLabel.Size = UDim2.new(0, 250, 0, 250)

	local tween3 = TweenService:Create(
		imageLabel,
		TweenInfo.new(0.5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
		{
			ImageTransparency = 1
		}
	)
	tween3:Play()

	task.wait(0.5)

	if screenGui then
		screenGui:Destroy()
	end
end

